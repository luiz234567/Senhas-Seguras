<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Segurança Digital - Senhas Seguras</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">
    <h1>🔒 Senhas Seguras</h1>

    <input type="password" id="senha" placeholder="Digite uma senha">

    <button onclick="mostrarSenha()">Mostrar/Ocultar</button>

    <div class="barra">
        <div id="forca"></div>
    </div>

    <p id="textoForca">Digite uma senha...</p>

    <ul>
        <li id="c1">✔ Mínimo de 8 caracteres</li>
        <li id="c2">✔ Letra maiúscula</li>
        <li id="c3">✔ Letra minúscula</li>
        <li id="c4">✔ Número</li>
        <li id="c5">✔ Caractere especial</li>
    </ul>
</div>

<script src="script.js"></script>

</body>
</html>
